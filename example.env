# ============ Required ============

# Telegram API credentials from https://my.telegram.org
API_ID=
API_HASH=

# Bot token from @BotFather
BOT_TOKEN=
# Your bot's username, without @
BOT_USERNAME=
# Display name used in messages
BOT_NAME=Music Bot

# Pyrogram session string for the ASSISTANT account — the user account that
# joins the voice chat and streams. Use a dedicated account (NOT one a human
# listens with: Telegram allows one voice-chat connection per account).
# Generate it with gen_session.py (see README).
SESSION_NAME=

# Space-separated numeric Telegram user ids with sudo rights
SUDO_USERS=

# ============ Optional ============

# Max track length in minutes
DURATION_LIMIT=240

# Downloads cache cap in MB (replays of the same Telegram file are instant while
# cached). Pruned oldest-first after each stream ends; 0 = delete after playing.
DOWNLOADS_CACHE_LIMIT_MB=4096

# Local media library (browse with /library, play by name with /lplay).
# LIBRARY_HOST_DIR : host folder to mount read-only (docker-compose). Leave the
#                    LIBRARY_* vars unset to disable the feature entirely.
# LIBRARY_ROOT     : the in-container mount path (keep as /library).
# LIBRARY_CATEGORIES: optional comma-separated allowlist of top-level folders to
#                    expose; empty = show every subfolder.
#LIBRARY_HOST_DIR=/path/to/your/videos
#LIBRARY_ROOT=/library
#LIBRARY_CATEGORIES=movies,shows,cartoons

# Shown in the rare "assistant is banned" message; the assistant's @username without @
ASSISTANT_NAME=

# Your @username (without @) — used for the "info" button and the /alive "Master" link.
# Leave empty to hide.
OWNER_NAME=
# Display name for the /alive "Master" line. Leave empty to hide.
ALIVE_NAME=

# Support group / updates channel for the buttons. A public username without @
# (e.g. mygroup) or an invite hash with a leading + (e.g. +AbCdEfGh123).
# Leave empty to hide the buttons.
GROUP_SUPPORT=
UPDATES_CHANNEL=

# Card images (URL or local file path). Defaults to a bundled placeholder.
# ALIVE_IMG  - /alive card
# IMG_1..4   - queue/now-playing cards
#ALIVE_IMG=
#IMG_1=
#IMG_2=
#IMG_3=
#IMG_4=

# Your fork's git URL — used by /update and the "Source Code" button. Empty to hide.
#UPSTREAM_REPO=

# Command prefixes (space separated)
#COMMAND_PREFIXES=/ ! .

# Optional proxy for reaching Telegram (scheme: socks5/socks4/http).
# Note: a SOCKS proxy carries only the signaling, not the voice UDP — for
# networks where Telegram is fully filtered, use a system-level VPN instead.
#PROXY_SCHEME=socks5
#PROXY_HOST=
#PROXY_PORT=1080
#PROXY_USER=
#PROXY_PASS=

# Hardware-accelerated transcoding: "" = CPU (libx264), "vaapi" = Intel/AMD GPU.
# For vaapi: copy docker-compose.override.example.yml -> docker-compose.override.yml
# (mounts /dev/dri + sets the VA driver), then set this to vaapi.
#TRANSCODE_HWACCEL=vaapi

# Internet-radio presets for /radio (replaces the built-in list). Name=URL pairs,
# comma-separated. .pls/.m3u playlists are auto-resolved to the real stream.
#RADIO_STATIONS=Groove Salad=https://somafm.com/groovesalad.pls,FIP=https://icecast.radiofrance.fr/fip-midfi.mp3
